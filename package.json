{
  "name": "@jaminb/glider",
  "version": "0.1.0",
  "description": "Conway's Game of Life canvas background animation",
  "author": "Jamin Becker",
  "license": "MIT",
  "keywords": ["conway", "game-of-life", "canvas", "animation", "background", "cellular-automata"],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
